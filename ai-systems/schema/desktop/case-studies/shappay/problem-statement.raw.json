                        "children": [
                            {
                                "id": "84:1247",
                                "kind": "text",
                                "name": "MostNigeriansHoldMultipleBankAccountsAcrossDifferentBanksEveryTransferMeansTypingA10DigitAccountNumberChoosingTheRightBankFromAGrowingListAndHopingYouGotItRight—MultipliedAcrossEveryAccountYouOwn",
                                "width": 516,
                                "height": 104,
                                "component": "MostNigeriansHoldMultipleBankAccountsAcrossDifferentBanksEveryTransferMeansTypingA10DigitAccountNumberChoosingTheRightBankFromAGrowingListAndHopingYouGotItRight—MultipliedAcrossEveryAccountYouOwn",
                                "position": "relational",
                                "text": {
                                    "content": "Most Nigerians hold multiple bank accounts across different banks. Every transfer means typing a 10-digit account number, choosing the right bank from a growing list, and hoping you got it right — multiplied across every account you own.",
                                    "typography": "body-default",
                                    "color": "color-text-primary",
                                    "textAlign": "left"
                                },
                                "semanticRole": "semantic",
                                "signals": {
                                    "nonInteractive": true
                                },
                                "context": {
                                    "zIndex": -1,
                                    "hierarchyDepth": 3
                                }
                            },
                            {
                                "id": "84:1248",
                                "kind": "text",
                                "name": "It is the single most error-prone moment in everyday payments and it scales terribly to merchants, who have no terminal and no way to get paid except by dictating account details out loud. The rails to fix this already exist. NIBSS NQR is Nigeria's national interoperable QR standard, built on the same EMVCo spec that powers India's UPI QR. The standard was there. The experience and the resolution engine beneath it was not.",
                                "width": 516,
                                "height": 182,
                                "position": "relational",
                                "text": {
                                    "content": "It is the single most error-prone moment in everyday payments and it scales terribly to merchants, who have no terminal and no way to get paid except by dictating account details out loud. The rails to fix this already exist. NIBSS NQR is Nigeria's national interoperable QR standard, built on the same EMVCo spec that powers India's UPI QR. The standard was there. The experience and the resolution engine beneath it was not.",
